<UserControl x:Class="MiniDbWpf.Views.HelpView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer>
        <StackPanel>
            <TextBlock Text="Help" Style="{StaticResource PageTitleStyle}"/>
            <Border Style="{StaticResource CardBorder}">
                <TextBlock Text="{Binding HelpText}" Foreground="#CCC" FontSize="14"
                           LineHeight="22" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
