<Window x:Class="MiniDbWpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MiniDbWpf.ViewModels"
        xmlns:views="clr-namespace:MiniDbWpf.Views"
        Title="Mini Database Creator" Height="780" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignDarkBackground}"
        FontFamily="Segoe UI Variable, Segoe UI">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CreateDatabaseViewModel}">
            <views:CreateDatabaseView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProfileViewModel}">
            <views:ProfileView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LogsViewModel}">
            <views:LogsView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HelpViewModel}">
            <views:HelpView DataContext="{Binding}" />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AboutViewModel}">
            <views:AboutView DataContext="{Binding}" />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Background="#151525" Grid.Column="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <!-- Logo + Toggle -->
                <StackPanel Margin="16,16,16,20" Orientation="Horizontal">
                    <Border Width="36" Height="36" Background="#7C3AED">
                        <TextBlock Text="🗄️" FontSize="18" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Mini DB" FontSize="14" FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Creator" FontSize="11" Foreground="#888"
                                   Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation Items -->
                <ItemsControl ItemsSource="{Binding NavigationItems}" Grid.Row="1" Margin="8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SidebarButtonStyle}"
                                    Command="{Binding DataContext.NavigateToTypeCommand,
                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding PageType.Name}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="•" FontSize="22"
                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                       VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1" Text="{Binding Title}"
                                               Margin="12,0,0,0" VerticalAlignment="Center"
                                               FontSize="14"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- User Info + Logout -->
                <Border Grid.Row="2" Background="#1A1A30" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="36" Height="36" Background="#3A3A5C">
                            <TextBlock Text="👤" FontSize="18" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUser.FullName}" FontSize="13"
                                       FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="{Binding CurrentUser.Role}" FontSize="11"
                                       Foreground="#888" Margin="0,-2,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="2" Style="{StaticResource TopBarButton}"
                                Command="{Binding LogoutCommand}"
                                ToolTip="Logout">
                            <TextBlock Text="✕" FontSize="18" Foreground="#FF5252" VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Background="#1A1A30" Padding="20,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Administrator Dashboard" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Foreground="White"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource TopBarButton}"
                                Command="{Binding ToggleThemeCommand}"
                                ToolTip="Toggle Theme" Margin="0,0,4,0">
                            <TextBlock Text="🌙" FontSize="18"
                                               Foreground="{DynamicResource MaterialDesignBody}" VerticalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource TopBarButton}" ToolTip="Notifications"
                                Margin="0,0,4,0">
                            <TextBlock Text="🔔" FontSize="16"
                                               Foreground="{DynamicResource MaterialDesignBody}" VerticalAlignment="Center"/>
                        </Button>

                        <Border Width="1" Height="24" Background="#3A3A5C" Margin="8,0"/>

                        <TextBlock Text="{Binding CurrentUser.Username}" VerticalAlignment="Center"
                                   Foreground="#AAA" FontSize="13" Margin="8,0,12,0"/>
                        <Button Style="{StaticResource TopBarButton}"
                                Command="{Binding LogoutCommand}"
                                ToolTip="Logout" Background="#3A1A1A">
                            <TextBlock Text="✕" FontSize="16" Foreground="#FF5252" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Page Content -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}"
                            Margin="24,20"/>
        </Grid>
    </Grid>
</Window>
