<UserControl x:Class="MiniDbWpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             >
    <ScrollViewer>
        <StackPanel>
            <TextBlock Text="{Binding WelcomeMessage}" FontSize="15" Foreground="#AAA" Margin="0,0,0,24"/>

            <!-- Stat Cards -->
            <ItemsControl ItemsSource="{Binding StatCards}" Margin="0,0,0,24">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4" Rows="1"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorder}" Margin="6">
                            <StackPanel>
                                <TextBlock Text="📊" FontSize="28"
                                                   Foreground="{Binding IconBrush}"
                                                   Margin="0,0,0,12" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding Value}" FontSize="28" FontWeight="Bold"
                                           Foreground="White"/>
                                <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#CCC" Margin="0,4,0,2"/>
                                <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#888"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Recent Activities -->
                <Border Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Recent Activities" FontSize="16" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding RecentActivities}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#BBB" FontSize="13"
                                               Margin="0,0,0,8"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Quick Actions -->
                <Border Grid.Column="2" Style="{StaticResource CardBorder}">
                    <StackPanel>
                        <TextBlock Text="Quick Actions" FontSize="16" FontWeight="SemiBold"
                                   Foreground="White" Margin="0,0,0,16"/>
                        <Button Content="New Database" Background="#7C3AED" Foreground="White"
                                BorderThickness="0" Height="40"
                                Cursor="Hand" Margin="0,0,0,10"
                                 />
                        <Button Content="View Logs" Background="#252540" Foreground="White"
                                BorderThickness="0" Height="40"
                                Cursor="Hand" Margin="0,0,0,10"
                                />
                        <Button Content="Refresh" Background="#252540" Foreground="White"
                                BorderThickness="0" Height="40"
                                Cursor="Hand" Command="{Binding RefreshCommand}"
                                />
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
