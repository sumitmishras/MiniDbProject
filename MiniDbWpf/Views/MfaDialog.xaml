<Window x:Class="MiniDbWpf.Views.MfaDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="MFA Verification" Height="260" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="16" Background="#1A1A2E">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.4" ShadowDepth="4" Color="Black"/>
        </Border.Effect>
        <StackPanel Margin="28,24" VerticalAlignment="Center">
            <TextBlock Text="MFA Verification" FontSize="18" FontWeight="Bold"
                       Foreground="White" TextAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="Enter the 6-digit code from your authenticator app"
                       Foreground="#AAA" FontSize="12" TextAlignment="Center" Margin="0,0,0,20"/>

            <TextBox x:Name="txtCode" Background="#1E1E32" Foreground="White"
                     BorderBrush="#3A3A5C" BorderThickness="1" Padding="12,10"
                     FontSize="24" Height="48" CaretBrush="#7C3AED"
                     TextAlignment="Center"
                     MaxLength="6" Margin="0,0,0,20"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Button Content="Cancel" Background="#3A3A5C" Foreground="White"
                        BorderThickness="0" Height="40" FontSize="14" Cursor="Hand"
                        material:ButtonAssist.CornerRadius="8"
                        IsCancel="True" Click="BtnCancel_Click"/>
                <Button Grid.Column="2" Content="Verify" Background="#7C3AED" Foreground="White"
                        BorderThickness="0" Height="40" FontSize="14" Cursor="Hand"
                        material:ButtonAssist.CornerRadius="8"
                        IsDefault="True" Click="BtnVerify_Click"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
