<Window x:Class="MiniDbWpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Login - Mini Database Creator" Height="520" Width="440"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="16" Background="#1A1A2E">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.4" ShadowDepth="4" Direction="270" Color="Black"/>
        </Border.Effect>
        <Grid>
            <StackPanel Margin="36,30" VerticalAlignment="Center">
                <Border Width="56" Height="56" CornerRadius="14" Background="#7C3AED"
                        HorizontalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="🗄️" FontSize="28" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Mini Database Creator" FontSize="22" FontWeight="Bold"
                           Foreground="White" TextAlignment="Center"/>
                <TextBlock Text="v2.0.0" FontSize="12" Foreground="#888"
                           TextAlignment="Center" Margin="0,0,0,28"/>

                <Border Background="#252540" CornerRadius="12" Padding="24">
                    <StackPanel>
                        <TextBlock Text="WELCOME BACK" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#7C3AED" Margin="0,0,0,16" />

                        <TextBlock Text="Username" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="txtUsername" Background="#1E1E32" Foreground="White"
                                 BorderBrush="#3A3A5C" BorderThickness="1" Padding="12,10"
                                 FontSize="14" Height="40" CaretBrush="#7C3AED"
                                 Margin="0,0,0,14"/>

                        <TextBlock Text="Password" Foreground="#AAA" FontSize="12" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="txtPassword" Background="#1E1E32" Foreground="White"
                                      BorderBrush="#3A3A5C" BorderThickness="1" Padding="12,10"
                                      FontSize="14" Height="40" CaretBrush="#7C3AED"
                                      Margin="0,0,0,20"/>

                        <Button x:Name="btnLogin" Content="SIGN IN"
                                Background="#7C3AED" Foreground="White"
                                BorderThickness="0" Height="44" FontSize="15"
                                FontWeight="SemiBold" Cursor="Hand"
                                material:ButtonAssist.CornerRadius="10"
                                Click="BtnLogin_Click" IsDefault="True"/>

                        <TextBlock x:Name="lblError" Foreground="#FF5252" FontSize="12"
                                   TextWrapping="Wrap" Visibility="Collapsed" Margin="0,12,0,0"/>
                        <TextBlock x:Name="lblInfo" Foreground="#69DB7C" FontSize="12"
                                   TextWrapping="Wrap" Visibility="Collapsed" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Demo: admin / Admin@123" Foreground="#555"
                           FontSize="11" TextAlignment="Center" Margin="0,16,0,0"/>
            </StackPanel>

            <Button Content="✕" Foreground="#888" Background="Transparent"
                    BorderThickness="0" FontSize="16" Cursor="Hand"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,12,12,0" Width="32" Height="32"
                    Click="BtnClose_Click" />
        </Grid>
    </Border>
</Window>
