<UserControl x:Class="MiniDbWpf.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:material="http://materialdesigninxaml.net/winfx/xaml/themes">
    <ScrollViewer>
        <StackPanel>
            <TextBlock Text="Settings" Style="{StaticResource PageTitleStyle}"/>

            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Application Settings" FontSize="16" FontWeight="SemiBold"
                               Foreground="White" Margin="0,0,0,16"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Dark Theme" Foreground="#CCC" FontSize="14"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding IsDarkTheme}"
                                          HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Auto-refresh Logs" Foreground="#CCC" FontSize="14"
                                       VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding AutoRefreshLogs}"
                                          HorizontalAlignment="Right"/>
                        </Grid>

                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Log Location" Foreground="#CCC" FontSize="14"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding LogLocation}" IsReadOnly="True"
                                     Background="#1E1E32" Foreground="#888" BorderBrush="#3A3A5C"
                                     BorderThickness="1" Padding="10,8" FontSize="13"
                                     Height="36" Margin="16,0"/>
                            <Button Grid.Column="2" Content="Browse" Background="#3A3A5C" Foreground="White"
                                    BorderThickness="0" Height="36" Cursor="Hand" Padding="12,0"
                                    material:ButtonAssist.CornerRadius="8"
                                    Command="{Binding BrowseLogLocationCommand}"/>
                        </Grid>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button Content="Save Settings" Background="#7C3AED" Foreground="White"
                                BorderThickness="0" Height="40" Cursor="Hand" Padding="24,0"
                                material:ButtonAssist.CornerRadius="8"
                                Command="{Binding SaveSettingsCommand}"/>
                        <Button Content="Reset Defaults" Background="#3A3A5C" Foreground="White"
                                BorderThickness="0" Height="40" Cursor="Hand" Padding="24,0"
                                Margin="10,0,0,0" material:ButtonAssist.CornerRadius="8"
                                Command="{Binding ResetDefaultsCommand}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding StatusText}" Foreground="#69DB7C" FontSize="12" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
