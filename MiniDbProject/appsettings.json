{
  "ApplicationSettings": {
    "ApplicationName": "Mini Database Project",
    "Version": "1.0.0",
    "Author": "Your Name",
    "BuildDate": "2026-07-10",
    "FrameworkVersion": "NET 10.0",
    "ConsoleWidth": 120,
    "ConsoleHeight": 40
  },
  "SqlServer": {
    "LocalInstance": "(localdb)\\MSSQLLocalDB",
    "ConnectionTimeoutSeconds": 30,
    "CommandTimeoutSeconds": 120
  },
  "Logging": {
    "LogDirectory": "Logs",
    "LogFileNamePattern": "app_{yyyyMMdd}.log",
    "MaxLogFiles": 30,
    "LogLevel": "Information"
  },
  "Authentication": {
    "MaxLoginAttempts": 5,
    "LockoutDurationMinutes": 15,
    "PasswordMinLength": 8,
    "RequireMfaByDefault": false,
    "SessionTimeoutMinutes": 60
  },
  "DatabaseCreation": {
    "ProgressUpdateIntervalMs": 500,
    "EnablePauseResume": false,
    "BackupBeforeCreate": false,
    "MaxScriptSizeMb": 100
  },
  "Security": {
    "HashIterations": 100000,
    "HashSaltSize": 16,
    "HashKeySize": 32
  }
}
